DIRECT_URL=
DATABASE_URL=

# CORS origin allowed to call /tasks and /habits — e.g. chrome-extension://<extension-id>
EXTENSION_ORIGIN=

# Used to verify Supabase-issued JWTs (Auth) — e.g. https://<project-ref>.supabase.co
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
SUPABASE_JWKS_URL=

app_id=
key=
secret=
cluster=

# Google OAuth client used to refresh a user's Calendar access token from their
# stored refresh token — must match the Google OAuth client configured in
# Supabase's Google provider settings (Auth > Providers > Google)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Shared secret for service-to-service auth with the n8n calendar-sync workflow.
# Sent as the X-Webhook-Secret header on both the outbound publish (al-quotes -> n8n,
# via QStash) and the inbound callback (n8n -> al-quotes, POST /webhooks/n8n/calendar-sync)
WEBHOOK_SECRET=

# n8n webhook URL that receives calendar sync jobs (published via QStash, not called directly)
CALENDAR_WEBHOOK_URL=

# Upstash QStash token used to durably publish calendar sync jobs to n8n
QSTASH_TOKEN=