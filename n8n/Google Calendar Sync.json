    {
      "parameters": {
        "method": "POST",
        "url": "=https://www.googleapis.com/calendar/v3/calendars/{{ $json.body.calendarId }}/events",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{ $json.body.googleAccessToken }}"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ {\n  summary: $json.body.entityType === 'task' ? $json.body.task.title : $json.body.entityType === 'event' ? $json.body.event.title : $json.body.habit.title,\n  description: $json.body.entityType === 'task' ? $json.body.task.description : $json.body.entityType === 'event' ? $json.body.event.description : $json.body.habit.description,\n  location: $json.body.entityType === 'event' ? $json.body.event.location : undefined,\n  start: {\n    dateTime: $json.resolvedStart,\n    timeZone: $json.resolvedTimeZone\n  },\n  end: {\n    dateTime: $json.resolvedEnd,\n    timeZone: $json.resolvedTimeZone\n  },\n  recurrence: $json.body.entityType === 'habit' ? [ $json.body.habit.rrule ] : ($json.body.entityType === 'event' && $json.body.event.isRecurring) ? [ $json.body.event.rrule ] : undefined\n} }}",
        "options": {}
      },
