generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
        
model Quotes {
  id          Int      @id @default(autoincrement())
  arabic      String?
  quote       String
  author      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Pictures {
  id          Int      @id @default(autoincrement())
  url         String
  source      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum Priority {
  Low
  Medium
  High
}

enum TaskStatus {
  TODO
  DOING
  DONE
}

enum HabitFrequency {
  daily
  weekly
}

model Task {
  id          Int        @id @default(autoincrement())
  userId      String
  title       String
  description String?
  startDate   DateTime?
  dueDate     DateTime?
  priority    Priority?
  status      TaskStatus @default(TODO)
  position    Float
  comments    Comment[]
  statusHistory TaskStatusHistory[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model TaskStatusHistory {
  id         Int        @id @default(autoincrement())
  taskId     Int
  task       Task       @relation(fields: [taskId], references: [id], onDelete: Cascade)
  fromStatus TaskStatus
  toStatus   TaskStatus
  changedAt  DateTime   @default(now())

  @@index([taskId])
}

model Comment {
  id        Int      @id @default(autoincrement())
  taskId    Int
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([taskId])
}

model Habit {
  id          Int            @id @default(autoincrement())
  userId      String
  title       String
  description String?
  priority    Priority?
  frequency   HabitFrequency
  checkIns    HabitCheckIn[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([userId])
}

model HabitCheckIn {
  id          Int      @id @default(autoincrement())
  habitId     Int
  habit       Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  periodStart DateTime
  completed   Boolean  @default(true)
  completedAt DateTime @default(now())

  @@unique([habitId, periodStart])
  @@index([habitId])
}

model ApiKey {
  id         Int       @id @default(autoincrement())
  userId     String
  hash       String    @unique
  label      String?
  createdAt  DateTime  @default(now())
  lastUsedAt DateTime?
  expiresAt  DateTime

  @@index([userId])
}